# ─────────────────────────────────────────────────────────────────────────────
# ShieldAI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=ShieldAI
APP_VERSION=0.2.0
DEBUG=false

# ── LLM Provider Keys (at least one required for non-mock usage) ──────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: use docker-compose (see docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://shieldai:shieldai@localhost:5432/shieldai

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────────────────────────
# Comma-separated list of valid caller API keys.
# Leave empty to run without auth (dev mode only).
API_KEYS_RAW=your-secret-key-1,your-secret-key-2

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Feature flags ─────────────────────────────────────────────────────────────
LOG_TO_DB=true
BLOCK_ON_HIGH_THREAT=true
REDACT_PII_DEFAULT=true
