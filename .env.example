# ──────────────────────────────────────────────────────────────────────────────
# ShieldAI — Environment Variables
#
# LOCAL DEV: copy this to .env and fill in your values
# RENDER: set these in the Render dashboard under "Environment"
#         (Render auto-fills DATABASE_URL and REDIS_URL from attached services)
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Keys ─────────────────────────────────────────────────────────
# At least one required for non-mock usage. Get from:
# OpenAI:    platform.openai.com/api-keys
# Anthropic: console.anthropic.com
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL:  use docker-compose (starts postgres automatically)
# RENDER: auto-injected when you attach a Postgres database — do not set manually
DATABASE_URL=postgresql+asyncpg://shieldai:shieldai@localhost:5432/shieldai

# ── Redis ─────────────────────────────────────────────────────────────────────
# LOCAL:  use docker-compose (starts redis automatically)
# RENDER: auto-injected when you attach Redis — do not set manually
#         On free plan: leave empty — rate limiter will fail open (safe)
REDIS_URL=redis://localhost:6379/0

# ── Authentication ────────────────────────────────────────────────────────────
# Comma-separated list of API keys your callers must send in X-ShieldAI-Key header
# Leave empty for dev mode (no auth required)
API_KEYS_RAW=your-secret-key-1,your-secret-key-2

# ── App settings ──────────────────────────────────────────────────────────────
APP_NAME=ShieldAI
APP_VERSION=0.2.0
DEBUG=false
LOG_TO_DB=true
BLOCK_ON_HIGH_THREAT=true
REDACT_PII_DEFAULT=true
RATE_LIMIT_PER_MINUTE=60
